{
  "input": {
    "default": {
      "background":         { "$value": "{color.surface-sunken}",  "$type": "color" },
      "color":              { "$value": "{color.on-surface}",      "$type": "color" },
      "placeholder-color":  { "$value": "{color.on-surface-faint}","$type": "color" },
      "border-color":       { "$value": "{color.border}",          "$type": "color" },
      "border-color-focus": { "$value": "{color.border-focus}",    "$type": "color" },
      "border-color-error": { "$value": "{color.error}",           "$type": "color" },
      "border-width":       { "$value": "{border-width.default}",  "$type": "dimension" },
      "border-width-focus": { "$value": "{border-width.focus}",    "$type": "dimension" },
      "radius":             { "$value": "{radius.interactive}",    "$type": "dimension" },
      "padding-x":          { "$value": "12px",                    "$type": "dimension" },
      "padding-y":          { "$value": "10px",                    "$type": "dimension" },
      "min-height":         { "$value": "40px",                    "$type": "dimension" }
    }
  }
}
