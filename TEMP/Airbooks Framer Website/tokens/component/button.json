{
  "button": {
    "primary": {
      "background":        { "$value": "{color.primary}",       "$type": "color" },
      "background-hover":  { "$value": "{color.primary-hover}", "$type": "color" },
      "color":             { "$value": "{color.on-primary}",    "$type": "color" },
      "radius":            { "$value": "{radius.interactive}",  "$type": "dimension" },
      "border-width":      { "$value": "0px",                   "$type": "dimension" },
      "padding-x":         { "$value": "18px",                  "$type": "dimension" },
      "padding-y":         { "$value": "10px",                  "$type": "dimension" },
      "min-height":        { "$value": "44px",                  "$type": "dimension", "$description": "WCAG 2.5.5 touch target minimum." }
    },
    "secondary": {
      "background":        { "$value": "transparent",                   "$type": "color" },
      "background-hover":  { "$value": "{color.surface-overlay}",       "$type": "color" },
      "color":             { "$value": "{color.on-surface}",            "$type": "color" },
      "border-color":      { "$value": "{color.border-strong}",         "$type": "color" },
      "border-color-hover":{ "$value": "{color.on-surface-faint}",      "$type": "color" },
      "border-width":      { "$value": "{border-width.default}",        "$type": "dimension" },
      "radius":            { "$value": "{radius.interactive}",          "$type": "dimension" },
      "padding-x":         { "$value": "18px",                          "$type": "dimension" },
      "padding-y":         { "$value": "10px",                          "$type": "dimension" },
      "min-height":        { "$value": "44px",                          "$type": "dimension" }
    }
  }
}
