  "color": {
    "$description": "Semantic color roles. Dark-only. Every on-* pairing WCAG AA verified via Sistema contrast API. Architecture: contextual/layered surfaces + on-* pairings.",
    "surface": {
      "$type": "color",
      "$value": "{palette.neutral.950}",
      "$description": "Default page background (#101011)"
    },
    "surface-raised": {
      "$type": "color",
      "$value": "#161820",
      "$description": "Elevated surfaces: cards, sheets, hero. Subtle cool lift from surface (#161820)."
    },
    "surface-overlay": {
      "$type": "color",
      "$value": "{palette.neutral.900}",
      "$description": "Modal / dialog / popover surface (neutral-900)."
    },
    "on-surface": {
      "$type": "color",
      "$value": "{palette.neutral.50}",
      "$description": "Primary text on surfaces. 18.2:1 on surface, 15.4:1 on raised"
    },
    "on-surface-muted": {
      "$type": "color",
      "$value": "{palette.neutral.350}",
      "$description": "Secondary/muted text. 7.1:1 surface, 6.0:1 raised, 5.1:1 overlay"
    },
    "border": {
      "$type": "color",
      "$value": "{palette.neutral.900}",
      "$description": "Default border / section dividers \u2014 subtle cool hairline against surface (neutral-900)."
    },
    "border-focus": {
